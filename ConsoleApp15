using System.Text.Json.Serialization;

namespace ConsoleApp15
{
    internal class Program
    {
        static void Main(string[] args)
        {
            var ser = new MySerializer();
            ser.Serialize();
            ser.Deserialize();
            var ser2 = new MyXMLSerializer();
            ser2.Serialize();
            ser2.Deserialize();
        }
        public class Student
        {
            private static int _counter = 0;
            public int ID { get; private set; }
            public string Name { get; private set; }
            public string Surname { get; private set; }
            public Subject[] Subjects { get; private set; }
            public Student(string name, string surname)
            {
                ID=_counter++;
                Name = name;
                Surname = surname;
                Subjects = new Subject[3]
                { 
                    new Subject("Math"),
                    new Subject("CS"),
                    new Subject("History")
                };
            }
            [JsonConstructor]
            [Newtonsoft.Json.JsonConstructor]
            public Student(string name, string surname, int id, Subject[] subjects)
            {
                ID = id;
                Name = name;
                Surname = surname;
                Subjects = subjects;
            }
            public void AddMarks(string subjectName, int[] marks)
            { 
                for (int i=0; i<Subjects.Length;i++)
                    if (Subjects[i].Name==subjectName)
                        Subjects[i].AddMark(marks);
            }
            public void AddMarks(Subject subject, int[] marks)
            {
                for (int i = 0; i < Subjects.Length; i++)
                    if (Subjects[i].Name == subject.Name)
                        Subjects[i].AddMark(marks);
            }

        }
        public class Subject
        {
            public List<int> _marks;
            public string Name {  get; private set; }
            public int[] Marks { get; private set; }
            public int FinalMark
            {
                get
                { 
                if (_marks != null && _marks.Length>0)  return (int)Math.Round(Marks.Average());
                    return 0;
                }
            }
            public Subject(string name)
            {
                Name = name;
                _marks = new List<int>();
                _marks.AddRange(marks);
            }
            [JsonConstructor]
            [Newtonsoft.Json.JsonConstructor]
            public void AddMark(int mark)
            {
                _marks.Add(mark);
            }
            public void AddMark(int[] mark)
            {
                _marks.AddRange(mark);
            }
        }
    }
}
